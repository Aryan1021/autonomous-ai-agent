# =====================================================
# Autonomous AI Agent - Environment Configuration
# =====================================================
# Copy this file to ".env" and replace the placeholder
# values with your own configuration before running
# the application.
# =====================================================


# =====================================================
# Google Gemini Configuration
# =====================================================

# Google AI Studio API Key
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Primary Gemini model used by the application
PRIMARY_MODEL=gemini-2.5-flash

# Backup models (comma-separated)
# These models are used automatically if the primary
# model is unavailable.
FALLBACK_MODELS=gemini-flash-latest,gemini-2.5-flash


# =====================================================
# LLM Configuration
# =====================================================

# Controls response randomness.
# Lower values = more deterministic responses.
# Recommended range: 0.0 - 1.0
TEMPERATURE=0.3

# Maximum number of retry attempts for failed API requests.
MAX_RETRIES=5

# Initial delay (in seconds) before retrying a failed request.
INITIAL_RETRY_DELAY=5

# Maximum number of self-correction/regeneration iterations.
MAX_REGENERATION_ITERATIONS=2


# =====================================================
# Logging Configuration
# =====================================================

# Available values:
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# =====================================================
# Document Generation
# =====================================================

# Include the AI Reflection Report in generated documents.
# 1 = Enabled
# 0 = Disabled
SHOW_REFLECTION_REPORT=1